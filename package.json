{
	"name": "pug-web-admin",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"dev:mock": "node ./scripts/with-env.mjs mock-api.env next dev",
		"dev:turbo": "next dev --turbopack",
		"dev:mock:turbo": "node ./scripts/with-env.mjs mock-api.env next dev --turbopack",
		"build": "next build --turbopack",
		"mock:api": "node ./scripts/with-env.mjs mock-api.env node ./scripts/mock-api.mjs",
		"trans": "node ./scripts/reorderTranslations.js dev && node ./scripts/checkMissingTranslations.js",
		"start": "next start",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write . && npm run lint:fix && tsc --noEmit && npm run trans",
		"format:check": "prettier --check . && npm run lint"
	},
	"dependencies": {
		"@hookform/resolvers": "5.2.2",
		"@radix-ui/colors": "3.0.0",
		"@radix-ui/react-accessible-icon": "1.1.8",
		"@radix-ui/react-accordion": "1.2.12",
		"@radix-ui/react-alert-dialog": "1.1.15",
		"@radix-ui/react-checkbox": "1.3.3",
		"@radix-ui/react-dialog": "1.1.15",
		"@radix-ui/react-dropdown-menu": "2.1.16",
		"@radix-ui/react-label": "2.1.8",
		"@radix-ui/react-popover": "1.1.15",
		"@radix-ui/react-radio-group": "1.3.8",
		"@radix-ui/react-scroll-area": "1.2.10",
		"@radix-ui/react-select": "2.2.6",
		"@radix-ui/react-separator": "1.1.8",
		"@radix-ui/react-switch": "1.2.6",
		"@radix-ui/react-tabs": "1.1.13",
		"@radix-ui/react-toggle": "1.1.10",
		"@radix-ui/react-toggle-group": "1.1.11",
		"@radix-ui/react-tooltip": "1.2.8",
		"@tanstack/react-query": "5.100.6",
		"@tanstack/react-query-devtools": "5.100.6",
		"@tanstack/react-table": "8.21.3",
		"clsx": "2.1.1",
		"date-fns": "4.1.0",
		"i18next": "26.0.8",
		"i18next-http-backend": "3.0.6",
		"jwt-decode": "4.0.0",
		"lucide-react": "1.14.0",
		"next": "16.2.4",
		"react": "19.2.5",
		"react-day-picker": "9.14.0",
		"react-dom": "19.2.5",
		"react-hook-form": "7.74.0",
		"react-i18next": "17.0.6",
		"sonner": "2.0.7",
		"zod": "4.4.1",
		"zustand": "5.0.12"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3",
		"@tailwindcss/postcss": "4",
		"@trivago/prettier-plugin-sort-imports": "6.0.2",
		"@types/node": "25",
		"@types/react": "19",
		"@types/react-dom": "19",
		"eslint": "9.39.4",
		"eslint-config-next": "16.2.4",
		"eslint-config-prettier": "10.1.8",
		"prettier": "3.8.3",
		"prettier-plugin-ini": "1.3.0",
		"prettier-plugin-packagejson": "3.0.2",
		"prettier-plugin-properties": "0.3.1",
		"prettier-plugin-tailwindcss": "0.8.0",
		"tailwindcss": "4",
		"typescript": "5.9.3"
	}
}
